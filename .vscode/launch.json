{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Editor",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/editor/editor.exe",
            "args": [],
            "cwd": "${workspaceFolder}/build/editor",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/MinGW/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Skip stepping into system headers",
                    "text": "-interpreter-exec console \"skip -gfi /usr/include/**/*\"",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Editor",
            "stopAtEntry": false
        },
        {
            "name": "Debug Application",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/application/application.exe",
            "args": [],
            "cwd": "${workspaceFolder}/build/application",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/MinGW/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Application",
            "stopAtEntry": false
        },
        {
            "name": "Launch Editor (no build)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/editor/editor.exe",
            "args": [],
            "cwd": "${workspaceFolder}/build/editor",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/MinGW/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "stopAtEntry": false
        }
    ]
}
